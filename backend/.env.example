# Copy this file to .env and fill in your values

# App
DEBUG=false

# PostgreSQL — URL-encode special chars in password (e.g. ! → %21)
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/prooflayer

# Redis
REDIS_URL=redis://localhost:6379

# Pinata (IPFS) — get keys at https://app.pinata.cloud/keys
PINATA_JWT=your_pinata_jwt_here
# Or use key+secret instead of JWT:
# PINATA_API_KEY=
# PINATA_SECRET_KEY=

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PROGRAM_ID=                        # leave blank for mock/dev mode
SOLANA_PAYER_SECRET_KEY=                  # base58 keypair, keep secret

# AI microservice
AI_SERVICE_URL=http://localhost:8001

# CORS — comma-separated origins
ALLOWED_ORIGINS=["http://localhost:3000"]
